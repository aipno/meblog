---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type BlogEntry = CollectionEntry<"blog">;

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	const map = new Map<string, BlogEntry[]>();

	for (const post of posts) {
		const categories = (post.data as any).categories as
			| string[]
			| undefined;
		if (!Array.isArray(categories)) continue;

		for (const category of categories) {
			if (!category) continue;
			const list = map.get(category) ?? [];
			list.push(post);
			map.set(category, list);
		}
	}

	return Array.from(map.entries()).map(([category, posts]) => ({
		params: { category },
		props: { category, posts },
	}));
}

interface Props {
	category: string;
	posts: BlogEntry[];
}

const { category, posts } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`分类：${category}`}
			description={`属于分类「${category}」的文章列表。`}
		/>
	</head>
	<body>
		<Header />
		<main class="category-page">
			<section class="category-header">
				<h1>分类：{category}</h1>
				<p class="summary">
					共 {posts.length} 篇文章
				</p>
				<a href="/categories" class="back-link">
					← 返回分类列表
				</a>
			</section>
			<section class="category-posts">
				{
					posts.length === 0 ? (
						<p class="empty">这个分类下还没有文章。</p>
					) : (
						<ul>
							{
								posts.map((post) => (
									<li>
										<a
											href={`/blog/${post.id}/`}
											class="category-post-card"
										>
											<h2>{post.data.title}</h2>
											<div class="meta">
												<FormattedDate
													date={post.data.pubDate}
												/>
											</div>
											<p class="excerpt">
												{post.data.description}
											</p>
										</a>
									</li>
								))
							}
						</ul>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
	<style>
		.category-page {
			max-width: 960px;
			margin: 0 auto;
			padding: 2rem 1rem 4rem;
		}
		.category-header {
			margin-bottom: 1.5rem;
		}
		.category-header h1 {
			margin: 0 0 0.5rem;
			font-size: 1.75rem;
		}
		.category-header .summary {
			margin: 0 0 0.5rem;
			color: rgb(var(--gray));
			font-size: 0.95rem;
		}
		.back-link {
			display: inline-block;
			font-size: 0.9rem;
			color: rgb(var(--accent));
			text-decoration: none;
		}
		.back-link:hover {
			text-decoration: underline;
		}
		.category-posts ul {
			list-style: none;
			padding: 0;
			margin: 0;
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}
		.category-posts li {
			margin: 0;
		}
		.category-post-card {
			display: block;
			padding: 1rem 1.25rem;
			border-radius: 0.75rem;
			border: 1px solid rgba(var(--gray), 0.3);
			text-decoration: none;
			color: inherit;
			background: white;
			transition: box-shadow 0.15s ease, transform 0.1s ease,
				border-color 0.15s ease;
		}
		.category-post-card:hover {
			box-shadow: 0 8px 20px rgba(var(--black), 0.06);
			transform: translateY(-1px);
			border-color: rgba(var(--accent), 0.7);
		}
		.category-post-card h2 {
			margin: 0 0 0.35rem;
			font-size: 1.1rem;
		}
		.category-post-card .meta {
			margin: 0 0 0.4rem;
			font-size: 0.85rem;
			color: rgb(var(--gray));
		}
		.category-post-card .excerpt {
			margin: 0;
			font-size: 0.95rem;
			color: rgb(var(--gray-dark));
		}
		.empty {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 0.95rem;
		}
		@media (max-width: 720px) {
			.category-page {
				padding-top: 1.5rem;
			}
			.category-header h1 {
				font-size: 1.5rem;
			}
		}
	</style>
</html>

