---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const categoryCounts = new Map<string, number>();

for (const post of posts) {
	const category = post.data.category;
	if (category) {
		categoryCounts.set(category, (categoryCounts.get(category) ?? 0) + 1);
	}
}

const allCategories = Array.from(categoryCounts.entries()).sort((a, b) =>
	a[0].localeCompare(b[0], "zh-Hans-CN"),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="分类" description="按分类浏览站点文章。" />
	</head>
	<body>
		<Header />
		<main class="categories-page">
			<section class="categories-header">
				<h1>文章分类</h1>
				<p class="summary">
					共 <strong>{allCategories.length}</strong> 个分类，覆盖 <strong
						>{posts.length}</strong
					> 篇文章。
				</p>
			</section>
			<section class="categories-list">
				<ul>
					{
						allCategories.map(([category, count]) => (
							<li>
								<a
									href={`/categories/${category}`}
									class="category-pill"
								>
									<span class="category-name">
										{category}
									</span>
									<span class="category-count">{count}</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body><style>
		.categories-page {
			max-width: 960px;
			margin: 0 auto;
			padding: 2rem 1rem 4rem;
		}
		.categories-header {
			margin-bottom: 2rem;
			text-align: center;
		}
		.categories-header h1 {
			margin: 0 0 0.75rem;
			font-size: 2rem;
			font-weight: 700;
			color: rgb(var(--black));
		}
		.categories-header .summary {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 1.1rem;
			line-height: 1.5;
		}
		.categories-header .summary strong {
			color: rgb(var(--accent));
			font-weight: 600;
		}
		.categories-list ul {
			display: flex;
			flex-wrap: wrap;
			gap: 1rem;
			list-style: none;
			padding: 0;
			margin: 1.5rem 0 0;
			justify-content: center;
		}
		.categories-list li {
			margin: 0;
		}
		.category-pill {
			display: inline-flex;
			align-items: center;
			gap: 0.75rem;
			padding: 0.6rem 1.2rem;
			border-radius: 50px;
			background: rgba(var(--accent), 0.08);
			color: inherit;
			text-decoration: none;
			border: 2px solid transparent;
			font-size: 1rem;
			font-weight: 500;
			transition:
				background 0.2s ease,
				border-color 0.2s ease,
				transform 0.15s ease,
				box-shadow 0.2s ease;
			box-shadow: 0 2px 8px rgba(var(--black), 0.08);
		}
		.category-pill:hover {
			background: rgba(var(--accent), 0.15);
			border-color: rgba(var(--accent), 0.4);
			transform: translateY(-2px);
			box-shadow: 0 4px 12px rgba(var(--black), 0.12);
		}
		.category-pill:active {
			transform: translateY(0);
		}
		.category-name {
			font-weight: 600;
			white-space: nowrap;
		}
		.category-count {
			min-width: 1.8rem;
			padding: 0.2rem 0.5rem;
			border-radius: 20px;
			background: rgba(var(--black), 0.1);
			font-size: 0.85rem;
			font-weight: 600;
			color: rgb(var(--accent));
			text-align: center;
		}
		@media (max-width: 720px) {
			.categories-page {
				padding-top: 1.5rem;
			}
			.categories-header h1 {
				font-size: 1.75rem;
			}
			.categories-header .summary {
				font-size: 1rem;
			}
			.category-pill {
				padding: 0.5rem 1rem;
				gap: 0.5rem;
				font-size: 0.95rem;
			}
			.category-count {
				min-width: 1.6rem;
				padding: 0.15rem 0.4rem;
				font-size: 0.8rem;
			}
		}
		@media (max-width: 480px) {
			.categories-list ul {
				gap: 0.75rem;
			}
			.category-pill {
				padding: 0.45rem 0.9rem;
				font-size: 0.9rem;
			}
		}
	</style>
</html>
