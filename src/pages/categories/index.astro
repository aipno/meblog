---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const categoryCounts = new Map<string, number>();

for (const post of posts) {
	const categories = post.data.categories ?? [];
	for (const category of categories) {
		categoryCounts.set(category, (categoryCounts.get(category) ?? 0) + 1);
	}
}

const allCategories = Array.from(categoryCounts.entries()).sort((a, b) =>
	a[0].localeCompare(b[0], "zh-Hans-CN"),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="分类" description="按分类浏览站点文章。" />
	</head>
	<body>
		<Header />
		<main class="categories-page">
			<section class="categories-header">
				<h1>分类</h1>
				<p class="summary">
					共 {allCategories.length} 个分类，覆盖 {posts.length} 篇文章。
				</p>
			</section>
			<section class="categories-list">
				<ul>
					{
						allCategories.map(([category, count]) => (
							<li>
								<a
									href={`/categories/${category}`}
									class="category-pill"
								>
									<span class="category-name">
										{category}
									</span>
									<span class="category-count">{count}</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body><style>
		.categories-page {
			max-width: 960px;
			margin: 0 auto;
			padding: 2rem 1rem 4rem;
		}
		.categories-header {
			margin-bottom: 1.5rem;
		}
		.categories-header h1 {
			margin: 0 0 0.5rem;
			font-size: 1.75rem;
		}
		.categories-header .summary {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 0.95rem;
		}
		.categories-list ul {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			list-style: none;
			padding: 0;
			margin: 1rem 0 0;
		}
		.categories-list li {
			margin: 0;
		}
		.category-pill {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.4rem 0.9rem;
			border-radius: 999px;
			background: rgba(var(--accent), 0.06);
			color: inherit;
			text-decoration: none;
			border: 1px solid rgba(var(--accent), 0.25);
			font-size: 0.95rem;
			transition:
				background 0.15s ease,
				border-color 0.15s ease,
				transform 0.1s ease;
		}
		.category-pill:hover {
			background: rgba(var(--accent), 0.12);
			border-color: rgba(var(--accent), 0.6);
			transform: translateY(-1px);
		}
		.category-name {
			font-weight: 500;
		}
		.category-count {
			min-width: 1.5rem;
			padding: 0.1rem 0.4rem;
			border-radius: 999px;
			background: rgba(var(--black), 0.05);
			font-size: 0.8rem;
		}
		@media (max-width: 720px) {
			.categories-page {
				padding-top: 1.5rem;
			}
			.categories-header h1 {
				font-size: 1.5rem;
			}
		}
	</style>
</html>
