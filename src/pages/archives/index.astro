---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const archiveMap = new Map<string, typeof posts>();

for (const post of posts) {
	const year = post.data.pubDate.getFullYear().toString();
	const month = String(post.data.pubDate.getMonth() + 1).padStart(2, "0");
	const yearMonth = `${year}-${month}`;
	const list = archiveMap.get(yearMonth) ?? [];
	list.push(post);
	archiveMap.set(yearMonth, list);
}

const archiveYearMonths = Array.from(archiveMap.keys()).sort((a, b) =>
	b.localeCompare(a),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="归档" description="按年月浏览站点所有文章归档。" />
	</head>
	<body>
		<Header />
		<main class="archives-page">
			<section class="archives-header">
				<h1>归档</h1>
				<p class="summary">
					共 {posts.length} 篇文章，按年月归档。
				</p>
			</section>
			<section class="archives-list">
				{
					archiveYearMonths.map((yearMonth) => (
						<section class="year-block">
							<h2>{yearMonth}</h2>
							<ul>
								{archiveMap.get(yearMonth)?.map((post) => (
									<li>
										<a
											href={`/blog/${post.id}/`}
											class="archive-item"
										>
											<span class="date">
												<FormattedDate
													date={post.data.pubDate}
												/>
											</span>
											<span class="title">
												{post.data.title}
											</span>
										</a>
									</li>
								))}
							</ul>
						</section>
					))
				}
			</section>
		</main>
		<Footer />
	</body><style>
		.archives-page {
			max-width: 960px;
			margin: 0 auto;
			padding: 2rem 1rem 4rem;
		}
		.archives-header {
			margin-bottom: 1.5rem;
		}
		.archives-header h1 {
			margin: 0 0 0.5rem;
			font-size: 1.75rem;
		}
		.archives-header .summary {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 0.95rem;
		}
		.archives-list {
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
			margin-top: 1rem;
		}
		.year-block h2 {
			margin: 0 0 0.5rem;
			font-size: 1.25rem;
		}
		.year-block ul {
			list-style: none;
			padding: 0;
			margin: 0;
			border-left: 2px solid rgba(var(--gray), 0.3);
		}
		.year-block li {
			margin: 0;
		}
		.archive-item {
			display: grid;
			grid-template-columns: minmax(120px, 160px) minmax(0, 1fr);
			column-gap: 1rem;
			padding: 0.4rem 0.75rem 0.4rem 0.9rem;
			position: relative;
			text-decoration: none;
			color: inherit;
			font-size: 0.95rem;
		}
		.archive-item::before {
			content: "";
			position: absolute;
			left: -6px;
			top: 50%;
			transform: translateY(-50%);
			width: 8px;
			height: 8px;
			border-radius: 999px;
			background: white;
			border: 2px solid rgba(var(--accent), 0.8);
		}
		.archive-item:hover {
			background: rgba(var(--black), 0.02);
		}
		.date {
			color: rgb(var(--gray));
		}
		.title {
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}
		@media (max-width: 720px) {
			.archives-page {
				padding-top: 1.5rem;
			}
			.archives-header h1 {
				font-size: 1.5rem;
			}
			.archive-item {
				grid-template-columns: minmax(100px, 130px) minmax(0, 1fr);
				column-gap: 0.75rem;
			}
		}
	</style>
</html>
