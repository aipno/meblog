---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const tagCounts = new Map<string, number>();

for (const post of posts) {
	const tags = post.data.tags ?? [];
	for (const tag of tags) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}

const allTags = Array.from(tagCounts.entries()).sort((a, b) =>
	a[0].localeCompare(b[0], "zh-Hans-CN"),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Tags" description="Browse articles by tags." />
	</head>
	<body>
		<Header />
		<main class="tags-page">
			<section class="tags-header">
				<h1>标签</h1>
				<p class="summary">
					共 {allTags.length} 个标签，覆盖 {posts.length} 篇文章。
				</p>
			</section>
			<section class="tags-list">
				<ul>
					{
						allTags.map(([tag, count]) => (
							<li>
								<a href={`/tags/${tag}`} class="tag-pill">
									<span class="tag-name">{tag}</span>
									<span class="tag-count">{count}</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body><style>
		.tags-page {
			max-width: 960px;
			margin: 0 auto;
			padding: 2rem 1rem 4rem;
		}
		.tags-header {
			margin-bottom: 1.5rem;
		}
		.tags-header h1 {
			margin: 0 0 0.5rem;
			font-size: 1.75rem;
		}
		.tags-header .summary {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 0.95rem;
		}
		.tags-list ul {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			list-style: none;
			padding: 0;
			margin: 1rem 0 0;
		}
		.tags-list li {
			margin: 0;
		}
		.tag-pill {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.4rem 0.9rem;
			border-radius: 999px;
			background: rgba(var(--accent), 0.06);
			color: inherit;
			text-decoration: none;
			border: 1px solid rgba(var(--accent), 0.25);
			font-size: 0.95rem;
			transition:
				background 0.15s ease,
				border-color 0.15s ease,
				transform 0.1s ease;
		}
		.tag-pill:hover {
			background: rgba(var(--accent), 0.12);
			border-color: rgba(var(--accent), 0.6);
			transform: translateY(-1px);
		}
		.tag-name {
			font-weight: 500;
		}
		.tag-count {
			min-width: 1.5rem;
			padding: 0.1rem 0.4rem;
			border-radius: 999px;
			background: rgba(var(--black), 0.05);
			font-size: 0.8rem;
		}
		@media (max-width: 720px) {
			.tags-page {
				padding-top: 1.5rem;
			}
			.tags-header h1 {
				font-size: 1.5rem;
			}
		}
	</style>
</html>
