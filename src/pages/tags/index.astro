---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const tagCounts = new Map<string, number>();

for (const post of posts) {
	const tags = post.data.tags ?? [];
	for (const tag of tags) {
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}

const allTags = Array.from(tagCounts.entries()).sort((a, b) =>
	a[0].localeCompare(b[0], "zh-Hans-CN"),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="标签" description="按标签浏览站点文章。" />
	</head>
	<body>
		<Header />
		<main class="tags-page">
			<section class="tags-header">
				<h1>文章标签</h1>
				<p class="summary">
					共 <strong>{allTags.length}</strong> 个标签，覆盖 <strong>{posts.length}</strong> 篇文章。
				</p>
			</section>
			<section class="tags-list">
				<ul>
					{
						allTags.map(([tag, count]) => (
							<li>
								<a href={`/tags/${tag}`} class="tag-pill">
									<span class="tag-name">{tag}</span>
									<span class="tag-count">{count}</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body><style>
		.tags-page {
			max-width: 960px;
			margin: 0 auto;
			padding: 2rem 1rem 4rem;
		}
		.tags-header {
			margin-bottom: 2rem;
			text-align: center;
		}
		.tags-header h1 {
			margin: 0 0 0.75rem;
			font-size: 2rem;
			font-weight: 700;
			color: rgb(var(--black));
		}
		.tags-header .summary {
			margin: 0;
			color: rgb(var(--gray));
			font-size: 1.1rem;
			line-height: 1.5;
		}
		.tags-header .summary strong {
			color: rgb(var(--accent));
			font-weight: 600;
		}
		.tags-list ul {
			display: flex;
			flex-wrap: wrap;
			gap: 1rem;
			list-style: none;
			padding: 0;
			margin: 1.5rem 0 0;
			justify-content: center;
		}
		.tags-list li {
			margin: 0;
		}
		.tag-pill {
			display: inline-flex;
			align-items: center;
			gap: 0.75rem;
			padding: 0.6rem 1.2rem;
			border-radius: 50px;
			background: rgba(var(--accent), 0.08);
			color: inherit;
			text-decoration: none;
			border: 2px solid transparent;
			font-size: 1rem;
			font-weight: 500;
			transition:
				background 0.2s ease,
				border-color 0.2s ease,
				transform 0.15s ease,
				box-shadow 0.2s ease;
			box-shadow: 0 2px 8px rgba(var(--black), 0.08);
		}
		.tag-pill:hover {
			background: rgba(var(--accent), 0.15);
			border-color: rgba(var(--accent), 0.4);
			transform: translateY(-2px);
			box-shadow: 0 4px 12px rgba(var(--black), 0.12);
		}
		.tag-pill:active {
			transform: translateY(0);
		}
		.tag-name {
			font-weight: 600;
			white-space: nowrap;
		}
		.tag-count {
			min-width: 1.8rem;
			padding: 0.2rem 0.5rem;
			border-radius: 20px;
			background: rgba(var(--black), 0.1);
			font-size: 0.85rem;
			font-weight: 600;
			color: rgb(var(--accent));
			text-align: center;
		}
		@media (max-width: 720px) {
			.tags-page {
				padding-top: 1.5rem;
			}
			.tags-header h1 {
				font-size: 1.75rem;
			}
			.tags-header .summary {
				font-size: 1rem;
			}
			.tag-pill {
				padding: 0.5rem 1rem;
				gap: 0.5rem;
				font-size: 0.95rem;
			}
			.tag-count {
				min-width: 1.6rem;
				padding: 0.15rem 0.4rem;
				font-size: 0.8rem;
			}
		}
		@media (max-width: 480px) {
			.tags-list ul {
				gap: 0.75rem;
			}
			.tag-pill {
				padding: 0.45rem 0.9rem;
				font-size: 0.9rem;
			}
		}
	</style>
</html>