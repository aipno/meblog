---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
			}

			/* хНЪховхИЧшбихо╣хЩи */
			.blog-list-container {
				padding: 2rem 0;
			}

			/* хНЪховхИЧшбицаЗщвШ */
			.blog-list-header {
				text-align: center;
				margin-bottom: 3rem;
			}

			.blog-list-title {
				font-size: 2.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 1rem;
				position: relative;
				display: inline-block;
			}

			.blog-list-title::after {
				content: "";
				position: absolute;
				bottom: -0.5rem;
				left: 50%;
				transform: translateX(-50%);
				width: 80px;
				height: 4px;
				background: linear-gradient(90deg, var(--accent), #667eea);
				border-radius: 2px;
			}

			.blog-list-subtitle {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.6;
			}

			/* хНЪховцЦЗчлахНбчЙЗ */
			.blog-cards {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
			}

			.blog-card {
				background: white;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 10px 30px rgba(var(--gray), 15%);
				transition: all 0.3s ease;
				display: flex;
				flex-direction: column;
				height: 100%;
				border: 1px solid rgba(var(--gray), 10%);
			}

			.blog-card:hover {
				transform: translateY(-8px);
				box-shadow: 0 20px 40px rgba(var(--gray), 25%);
				border-color: rgba(var(--accent), 20%);
			}

			/* хНбчЙЗхд┤щГи - хЫ╛чЙЗхМ║хЯЯ */
			.card-image-wrapper {
				position: relative;
				height: 200px;
				overflow: hidden;
			}

			.card-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.4s ease;
			}

			.blog-card:hover .card-image {
				transform: scale(1.05);
			}

			/* хНбчЙЗхЖЕхо╣хМ║хЯЯ */
			.card-content {
				padding: 1.5rem;
				flex-grow: 1;
				display: flex;
				flex-direction: column;
			}

			.card-title {
				font-size: 1.5rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 1rem 0;
				line-height: 1.4;
				transition: color 0.3s ease;
			}

			.blog-card:hover .card-title {
				color: var(--accent);
			}

			.card-excerpt {
				color: rgb(var(--gray));
				font-size: 1rem;
				line-height: 1.6;
				margin-bottom: 1.5rem;
				flex-grow: 1;
			}

			.card-meta {
				display: flex;
				align-items: center;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin-top: auto;
			}

			.card-date {
				margin-right: 1rem;
				display: flex;
				align-items: center;
			}

			.card-date svg {
				width: 14px;
				height: 14px;
				margin-right: 0.5rem;
				fill: currentColor;
			}

			.card-read-more {
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				transition: all 0.3s ease;
			}

			.card-read-more:hover {
				color: var(--accent-dark);
				padding-right: 4px;
			}

			.card-read-more svg {
				width: 16px;
				height: 16px;
				margin-left: 4px;
				transition: transform 0.3s ease;
			}

			.card-read-more:hover svg {
				transform: translateX(2px);
			}

			/* хУНх║Фх╝Пшо╛шоб */
			@media (max-width: 768px) {
				main {
					width: 100%;
					padding: 0 1rem;
				}

				.blog-list-title {
					font-size: 2rem;
				}

				.blog-cards {
					grid-template-columns: 1fr;
				}

				.card-image-wrapper {
					height: 180px;
				}

				.card-title {
					font-size: 1.3rem;
				}

				.blog-list-header {
					margin-bottom: 2rem;
				}
			}

			@media (max-width: 480px) {
				.blog-list-title {
					font-size: 1.8rem;
				}

				.card-image-wrapper {
					height: 160px;
				}

				.card-content {
					padding: 1.2rem;
				}

				.card-title {
					font-size: 1.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-list-container">
				<div class="blog-list-header">
					<h1 class="blog-list-title">цКАцЬпхНЪхов</h1>
					<p class="blog-list-subtitle">
						хИЖф║лхоЙхЕицКАцЬпуАБч│╗ч╗Яч╝ЦчиЛхТМхЙНц▓┐чаФчй╢чЪДц╖▒х║жцЦЗчла
					</p>
				</div>

				<div class="blog-cards">
					{
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="blog-card">
								{post.data.heroImage && (
									<div class="card-image-wrapper">
										<Image
											width={600}
											height={300}
											src={post.data.heroImage}
											alt={post.data.title}
											class="card-image"
											loading="lazy"
										/>
									</div>
								)}
								<div class="card-content">
									<h3 class="card-title">
										{post.data.title}
									</h3>
									<p class="card-excerpt">
										{post.data.description ||
											(post.body
												? post.body.slice(0, 120) +
													"..."
												: "цЪВцЧацСШшжБ")}
									</p>
									<div class="card-meta">
										<div class="card-date">
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<rect
													x="3"
													y="4"
													width="18"
													height="18"
													rx="2"
													ry="2"
												/>
												<line
													x1="16"
													y1="2"
													x2="16"
													y2="6"
												/>
												<line
													x1="8"
													y1="2"
													x2="8"
													y2="6"
												/>
												<line
													x1="3"
													y1="10"
													x2="21"
													y2="10"
												/>
											</svg>
											<FormattedDate
												date={post.data.pubDate}
											/>
										</div>
										<span class="card-read-more">
											щШЕшп╗цЫ┤хдЪ
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<path d="M9 14l2-2m0 0l4 4m-4-4l2-2m-2 2l4-4" />
											</svg>
										</span>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
