---
import { Image } from "astro:assets";
import { getCollection, type CollectionEntry } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import Pagination from "../../components/Pagination.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

type BlogEntry = CollectionEntry<"blog">;

const allPosts: BlogEntry[] = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const POSTS_PER_PAGE = 10;
const currentPage = 1;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const endIndex = startIndex + POSTS_PER_PAGE;
const posts = allPosts.slice(startIndex, endIndex);

const getPageUrl = (pageNum: number) => {
	if (pageNum === 1) return "/blog/";
	return `/blog/page/${pageNum}/`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.blog-list-container {
				padding: 2rem 0;
			}
			.blog-list-header {
				text-align: center;
				margin-bottom: 3rem;
			}
			.blog-list-title {
				font-size: 2.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 1rem;
				position: relative;
				display: inline-block;
			}
			.blog-list-title::after {
				content: "";
				position: absolute;
				bottom: -0.5rem;
				left: 50%;
				transform: translateX(-50%);
				width: 80px;
				height: 4px;
				background: linear-gradient(90deg, var(--accent), #667eea);
				border-radius: 2px;
			}
			.blog-list-subtitle {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.6;
			}
			.blog-cards {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				max-width: 800px;
				margin: 0 auto;
			}
			.blog-card {
				background: white;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 4px 12px rgba(var(--gray), 0.1);
				transition: all 0.3s ease;
				display: flex;
				flex-direction: row;
				border: 1px solid rgba(var(--gray), 0.1);
				max-width: 100%;
				text-decoration: none;
			}
			@media (max-width: 768px) {
				.blog-card {
					flex-direction: column;
				}
			}
			.blog-card:hover {
				box-shadow: 0 12px 32px rgba(var(--gray), 0.25);
				border-color: rgba(var(--accent), 0.2);
				transform: translateY(-2px);
			}
			.card-image-wrapper {
				position: relative;
				width: 300px;
				min-width: 300px;
				height: 200px;
				overflow: hidden;
			}
			@media (max-width: 768px) {
				.card-image-wrapper {
					width: 100%;
					min-width: unset;
					height: 200px;
				}
			}
			.card-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s ease;
			}
			.blog-card:hover .card-image {
				transform: scale(1.05);
			}
			.card-content {
				padding: 1.5rem;
				flex-grow: 1;
				display: flex;
				flex-direction: column;
			}
			.card-title {
				font-size: 1.5rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 1rem 0;
				line-height: 1.4;
				transition: color 0.3s ease;
			}
			.blog-card:hover .card-title {
				color: var(--accent);
			}
			.card-excerpt {
				color: rgb(var(--gray));
				font-size: 1rem;
				line-height: 1.6;
				margin-bottom: 1.5rem;
				flex-grow: 1;
			}
			.card-meta {
				display: flex;
				align-items: center;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin-top: auto;
			}
			.card-date {
				margin-right: 1rem;
				display: flex;
				align-items: center;
			}
			.card-date svg {
				width: 14px;
				height: 14px;
				margin-right: 0.5rem;
				fill: currentColor;
			}
			.card-read-more {
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				transition: all 0.3s ease;
			}
			.card-read-more:hover {
				color: var(--accent-dark);
				padding-right: 4px;
			}
			.card-read-more svg {
				width: 16px;
				height: 16px;
				margin-left: 4px;
				transition: transform 0.3s ease;
			}
			.card-read-more:hover svg {
				transform: translateX(2px);
			}
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.5rem;
				margin: 3rem 0;
				padding: 1rem;
			}
			.pagination-info {
				color: rgb(var(--gray));
				font-size: 1rem;
				margin: 0 1rem;
			}
			.pagination-button {
				padding: 0.6rem 1.2rem;
				background: white;
				border: 1px solid rgba(var(--gray), 0.2);
				border-radius: 8px;
				color: rgb(var(--black));
				text-decoration: none;
				font-weight: 500;
				transition: all 0.3s ease;
				min-width: 40px;
				text-align: center;
				font-size: 1rem;
			}
			.pagination-button:hover {
				background: rgba(var(--gray), 0.05);
				border-color: rgba(var(--gray), 0.4);
				transform: translateY(-2px);
			}
			.pagination-button.active {
				background: var(--accent);
				color: white;
				border-color: var(--accent);
				box-shadow: 0 4px 12px rgba(var(--accent), 0.3);
			}
			.pagination-ellipsis {
				color: rgb(var(--gray));
				padding: 0.6rem 0.8rem;
				font-size: 1rem;
			}
			@media (max-width: 768px) {
				.pagination {
					gap: 0.5rem;
					flex-wrap: wrap;
				}
				.pagination-button {
					padding: 0.4rem 0.8rem;
					font-size: 0.9rem;
					min-width: 36px;
				}
				.pagination-info {
					font-size: 0.9rem;
					margin: 0 0.5rem;
				}
				main {
					width: 100%;
					padding: 0 1rem;
				}
				.blog-list-title {
					font-size: 2rem;
				}
				.card-image-wrapper {
					height: 180px;
				}
				.card-title {
					font-size: 1.3rem;
				}
				.blog-list-header {
					margin-bottom: 2rem;
				}
			}
			@media (max-width: 480px) {
				.blog-list-title {
					font-size: 1.8rem;
				}
				.card-image-wrapper {
					height: 160px;
				}
				.card-content {
					padding: 1.2rem;
				}
				.card-title {
					font-size: 1.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-list-container">
				<header class="blog-list-header">
					<h1 class="blog-list-title">博客文章</h1>
					<p class="blog-list-subtitle">
						分享技术心得与生活感悟，共 {allPosts.length} 篇文章
					</p>
				</header>
				<div class="blog-cards">
					{
						posts.map((post: BlogEntry) => (
							<a href={`/blog/${post.id}/`} class="blog-card">
								{post.data.heroImage && (
									<div class="card-image-wrapper">
										<Image
											width={600}
											height={300}
											src={post.data.heroImage}
											alt={post.data.title}
											class="card-image"
											loading="lazy"
										/>
									</div>
								)}
								<div class="card-content">
									<h3 class="card-title">
										{post.data.title}
									</h3>
									<p class="card-excerpt">
										{post.data.description ||
											(post.body
												? post.body.slice(0, 120) +
													"..."
												: "暂无摘要")}
									</p>
									<div class="card-meta">
										<div class="card-date">
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<rect
													x="3"
													y="4"
													width="18"
													height="18"
													rx="2"
													ry="2"
												/>
												<line
													x1="16"
													y1="2"
													x2="16"
													y2="6"
												/>
												<line
													x1="8"
													y1="2"
													x2="8"
													y2="6"
												/>
												<line
													x1="3"
													y1="10"
													x2="21"
													y2="10"
												/>
											</svg>
											<FormattedDate
												date={post.data.pubDate}
											/>
										</div>
										<span class="card-read-more">
											阅读更多
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<path d="M9 14l2-2m0 0l4 4m-4-4l2-2m-2 2l4-4" />
											</svg>
										</span>
									</div>
								</div>
							</a>
						))
					}
				</div>
				<Pagination
					currentPage={currentPage}
					totalPages={totalPages}
					getPageUrl={getPageUrl}
				/>
		<Footer />
		</main>
		<Footer />
	</body>
</html>
