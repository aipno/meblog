---
/**
 * 博客分页页面文件
 * 
 * 作用：
 * - 处理博客文章列表的分页路由
 * - 根据页码参数显示对应的文章列表
 * - 实现分页导航和URL参数处理
 * - 与主页共享相同的文章展示逻辑
 * 
 * 相关文件：
 * - src/pages/blog/index.astro：博客主页（第1页）
 * - src/components/Pagination.astro：分页组件
 * - src/utils/blogUtils.ts：博客工具函数
 * - src/consts.ts：分页常量配置
 * 
 * 路由特点：
 * - [page]动态参数接收页码
 * - 与主页共用文章渲染逻辑
 * - 支持SEO友好的分页URL
 * - 实现服务端静态路径生成
 */

import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";
import Pagination from "@/components/Pagination.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";

// 生成所有分页路径
export async function getStaticPaths() {
	const allPosts = (await getCollection("blog")).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	const POSTS_PER_PAGE = 10;
	const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

	// 只生成第2页及之后的路径（第1页由/blog/处理）
	const paths = [];
	for (let page = 2; page <= totalPages; page++) {
		paths.push({
			params: { page: page.toString() },
		});
	}

	return paths;
}

// 获取页面参数
const { page } = Astro.params;
const currentPage = parseInt(page || "1");

// 获取所有博客文章并按发布日期排序
const allPosts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 分页配置
const POSTS_PER_PAGE = 10;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

// 验证页面有效性
if (currentPage < 1 || currentPage > totalPages) {
	throw new Error("Page not found");
}

// 计算当前页的文章
const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const endIndex = startIndex + POSTS_PER_PAGE;
const posts = allPosts.slice(startIndex, endIndex);

// 生成分页链接
const getPageUrl = (pageNum: number) => {
	if (pageNum === 1) return "/blog/";
	return `/blog/page/${pageNum}/`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${SITE_TITLE} - 第${currentPage}页`}
			description={`${SITE_DESCRIPTION} - 第${currentPage}页，共${totalPages}页`}
		/>
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
			}

			/* 博客列表容器 */
			.blog-list-container {
				padding: 2rem 0;
			}

			/* 博客列表标题 */
			.blog-list-header {
				text-align: center;
				margin-bottom: 3rem;
			}

			.blog-list-title {
				font-size: 2.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 1rem;
				position: relative;
				display: inline-block;
			}

			.blog-list-title::after {
				content: "";
				position: absolute;
				bottom: -0.5rem;
				left: 50%;
				transform: translateX(-50%);
				width: 80px;
				height: 4px;
				background: linear-gradient(90deg, var(--accent), #667eea);
				border-radius: 2px;
			}

			.blog-list-subtitle {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.6;
			}

			/* 博客文章卡片 */
			.blog-cards {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				max-width: 800px;
				margin: 0 auto;
			}

			.blog-card {
				background: white;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 4px 12px rgba(var(--gray), 10%);
				transition: all 0.3s ease;
				display: flex;
				flex-direction: row;
				height: auto;
				border: 1px solid rgba(var(--gray), 10%);
				max-width: 100%;
				text-decoration: none;
			}

			@media (max-width: 768px) {
				.blog-card {
					flex-direction: column;
				}
			}

			.blog-card:hover {
				box-shadow: 0 12px 32px rgba(var(--gray), 25%);
				border-color: rgba(var(--accent), 20%);
				transform: translateY(-2px);
			}

			/* 卡片头部 - 图片区域 */
			.card-image-wrapper {
				position: relative;
				width: 300px;
				min-width: 300px;
				height: 200px;
				overflow: hidden;
			}

			@media (max-width: 768px) {
				.card-image-wrapper {
					width: 100%;
					min-width: unset;
					height: 200px;
				}
			}

			.card-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s ease;
			}

			.blog-card:hover .card-image {
				transform: scale(1.05);
			}

			/* 卡片内容区域 */
			.card-content {
				padding: 1.5rem;
				flex-grow: 1;
				display: flex;
				flex-direction: column;
			}

			.card-title {
				font-size: 1.5rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 1rem 0;
				line-height: 1.4;
				transition: color 0.3s ease;
			}

			.blog-card:hover .card-title {
				color: var(--accent);
			}

			.card-excerpt {
				color: rgb(var(--gray));
				font-size: 1rem;
				line-height: 1.6;
				margin-bottom: 1.5rem;
				flex-grow: 1;
			}

			.card-meta {
				display: flex;
				align-items: center;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin-top: auto;
			}

			.card-date {
				margin-right: 1rem;
				display: flex;
				align-items: center;
			}

			.card-date svg {
				width: 14px;
				height: 14px;
				margin-right: 0.5rem;
				fill: currentColor;
			}

			.card-read-more {
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				transition: all 0.3s ease;
			}

			.card-read-more:hover {
				color: var(--accent-dark);
				padding-right: 4px;
			}

			.card-read-more svg {
				width: 16px;
				height: 16px;
				margin-left: 4px;
				transition: transform 0.3s ease;
			}

			.card-read-more:hover svg {
				transform: translateX(2px);
			}

			/* 响应式设计 */
			@media (max-width: 768px) {
				main {
					width: 100%;
					padding: 0 1rem;
				}

				.blog-list-title {
					font-size: 2rem;
				}

				.card-image-wrapper {
					height: 180px;
				}

				.card-title {
					font-size: 1.3rem;
				}

				.blog-list-header {
					margin-bottom: 2rem;
				}
			}

			@media (max-width: 480px) {
				.blog-list-title {
					font-size: 1.8rem;
				}

				.card-image-wrapper {
					height: 160px;
				}

				.card-content {
					padding: 1.2rem;
				}

				.card-title {
					font-size: 1.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-list-container">
				<header class="blog-list-header">
					<h1 class="blog-list-title">博客文章</h1>
					<p class="blog-list-subtitle">
						分享技术心得与生活感悟，共 {allPosts.length} 篇文章
					</p>
				</header>

				<div class="blog-cards">
					{
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="blog-card">
								{post.data.heroImage && (
									<div class="card-image-wrapper">
										<Image
											width={600}
											height={300}
											src={post.data.heroImage}
											alt={post.data.title}
											class="card-image"
											loading="lazy"
										/>
									</div>
								)}
								<div class="card-content">
									<h3 class="card-title">
										{post.data.title}
									</h3>
									<p class="card-excerpt">
										{post.data.description ||
											(post.body
												? post.body.slice(0, 120) +
													"..."
												: "暂无摘要")}
									</p>
									<div class="card-meta">
										<div class="card-date">
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<rect
													x="3"
													y="4"
													width="18"
													height="18"
													rx="2"
													ry="2"
												/>
												<line
													x1="16"
													y1="2"
													x2="16"
													y2="6"
												/>
												<line
													x1="8"
													y1="2"
													x2="8"
													y2="6"
												/>
												<line
													x1="3"
													y1="10"
													x2="21"
													y2="10"
												/>
											</svg>
											<FormattedDate
												date={post.data.pubDate}
											/>
										</div>
										<span class="card-read-more">
											阅读更多
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
											>
												<path d="M9 14l2-2m0 0l4 4m-4-4l2-2m-2 2l4-4" />
											</svg>
										</span>
									</div>
								</div>
							</a>
						))
					}
				</div>

				<Pagination
					currentPage={currentPage}
					totalPages={totalPages}
					getPageUrl={getPageUrl}
				/>
			</div>
		</main>
		<Footer />
	</body>
</html>
