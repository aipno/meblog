---
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";

// 获取最新3篇文章
const latestPosts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="stylesheet" href="/fontawesome/fontawesome.min.css" />
		<link rel="stylesheet" href="/fontawesome/brands.min.css" />
		<link rel="stylesheet" href="/fontawesome/solid.min.css" />
	</head>
	<body>
		<div class="page-root">
			<div class="hero">
				<div class="hero-overlay">
					<Header />
					<div class="hero-content">
						<h1 class="title">{SITE_TITLE}</h1>
						<p class="subtitle" id="hitokoto">加载一言中…</p>
					</div>
				</div>
				<!-- 将联系组件移到hero容器内部 -->
				<div class="contact-container">
					<a
						href="https://github.com/your-username"
						class="contact-icon"
						title="GitHub"
					>
						<i class="fab fa-github"></i>
					</a>
					<a
						href="mailto:contact@example.com"
						class="contact-icon"
						title="Email"
					>
						<i class="fas fa-at"></i>
					</a>
					<div class="contact-divider">|</div>
					<div class="contact-icon-with-tooltip" title="图片">
						<a href="#" class="contact-icon">
							<i class="fas fa-image"></i>
						</a>
						<!-- 气泡聊天框子组件 -->
						<div class="tooltip-bubble">
							<div class="tooltip-content"></div>
							<div class="tooltip-arrow"></div>
						</div>
					</div>
				</div>
			</div>

			<!-- 最新文章组件 -->
			<div class="latest-posts-section">
				<div class="section-header">
					<h2 class="section-title">最新文章</h2>
					<a href="/blog/" class="view-all-link">查看更多</a>
				</div>

				<div class="posts-grid">
					{
						latestPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								{post.data.heroImage && (
									<div class="post-image-wrapper">
										<img
											src={post.data.heroImage.toString()}
											alt={post.data.title}
											class="post-image"
											loading="lazy"
										/>
									</div>
								)}
								<div class="post-content">
									<!-- 分类标签 -->
									{post.data.categories && post.data.categories.length > 0 && (
										<span class="post-category">
											{post.data.categories[0]}
										</span>
									)}
									
									<h3 class="post-title">
										{post.data.title}
									</h3>
									
									<!-- 标签展示 -->
									{post.data.tags && post.data.tags.length > 0 && (
										<div class="post-tags">
											{post.data.tags.map((tag, index) => (
												<span class="post-tag">
													{tag}
												</span>
											))}
										</div>
									)}
									
									<div class="post-meta">
										<span class="post-date">
											<svg
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												width="14"
												height="14"
											>
												<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
												<line x1="16" y1="2" x2="16" y2="6"/>
												<line x1="8" y1="2" x2="8" y2="6"/>
												<line x1="3" y1="10" x2="21" y2="10"/>
											</svg>
											<span>{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</span>
										</span>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</div>

			<Footer />
		</div>
		<script>
			// 在客户端执行
			let imageCopyright = "";
			let imageTitle = "";

			async function loadCopyrightInfo() {
				try {
					const response = await fetch(
						"https://bing.api.iswxl.cn/copyright.php",
					);
					const data = await response.json();
					imageCopyright = data.copyright || "";
					imageTitle = data.title || "";

					// 更新DOM中的内容
					const tooltipContent =
						document.querySelector(".tooltip-content");
					if (tooltipContent) {
						tooltipContent.innerHTML = `<p style="font-size: 1.2rem">${imageTitle}</p><p>${imageCopyright}</p>`;
					}
				} catch (error) {
					console.error("获取版权信息失败:", error);
				}
			}

			// 页面加载完成后执行
			if (typeof window !== "undefined") {
				loadCopyrightInfo();
			}

			if (typeof window !== "undefined") {
				const hero = document.querySelector(".hero");

				if (hero) {
					hero.setAttribute(
						"style",
						"background-image: url('https://bing.api.iswxl.cn');",
					);
				}

				// 增强版打字机效果函数 - 支持删除和循环
				function advancedTypeWriter(
					element: HTMLElement,
					texts: string[],
					typeSpeed: number = 150,
					deleteSpeed: number = 100,
					pauseTime: number = 2000,
				) {
					let textIndex = 0;
					let charIndex = 0;
					let isDeleting = false;
					let currentText = texts[0];

					function type() {
						// 更新当前显示的文本
						const fullText = isDeleting
							? currentText.substring(0, charIndex - 1)
							: currentText.substring(0, charIndex + 1);

						element.textContent = fullText;
						element.setAttribute("data-text", fullText);

						// 添加视觉反馈类
						if (isDeleting) {
							element.classList.add("changing");
						} else {
							element.classList.remove("changing");
						}

						if (!isDeleting) {
							charIndex++;
							// 打字完成
							if (charIndex === currentText.length) {
								isDeleting = true;
								setTimeout(type, pauseTime); // 暂停后开始删除
								return;
							}
						} else {
							charIndex--;
							// 删除完成
							if (charIndex === 0) {
								isDeleting = false;
								textIndex = (textIndex + 1) % texts.length; // 循环到下一个文本
								currentText = texts[textIndex];
								element.classList.remove("changing");
								setTimeout(type, 500); // 删除完成后短暂暂停
								return;
							}
						}

						// 设置下次调用的时间间隔
						const timeout = isDeleting ? deleteSpeed : typeSpeed;
						setTimeout(type, timeout);
					}

					// 启动打字机
					type();
				}

				// 获取多条一言并应用循环打字机效果
				async function startTypewriterLoop() {
					try {
						// 获取多条一言
						const promises = Array.from({ length: 5 }, () =>
							fetch("https://v1.hitokoto.cn?encode=text").then(
								(res) => res.text(),
							),
						);

						const texts = await Promise.all(promises);
						const el = document.getElementById("hitokoto");

						if (el) {
							// 应用循环打字机效果
							advancedTypeWriter(el, texts, 120, 80, 2500);
						}
					} catch (error) {
						const el = document.getElementById("hitokoto");
						if (el) {
							el.textContent = "一言加载失败";
						}
					}
				}

				// 启动循环打字机
				startTypewriterLoop();
			}
		</script>
		<style>
			.page-root {
				min-height: 100vh;
				display: flex;
				flex-direction: column;
			}
			.hero {
				position: relative;
				min-height: 100vh;
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
			}
			.hero-overlay {
				position: relative;
				min-height: inherit;
				/* background: linear-gradient(
					to bottom,
					rgba(0, 0, 0, 0.4),
					rgba(0, 0, 0, 0.3),
					rgba(255, 255, 255, 0.2)
				); */
				display: flex;
				flex-direction: column;
			}
			.hero-content {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 0;
				color: #fff;
				flex: 1;
			}
			.hero-content .title {
				margin: 0 0 1rem;
				font-size: 2.8rem;
				text-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
			}
			.hero-content .subtitle {
				margin: 0;
				font-size: 1.2rem;
				max-width: 640px;
				text-shadow: 0 4px 16px rgba(0, 0, 0, 0.6);
				/* 打字机效果相关样式 */
				position: relative;
				min-height: 1.5em; /* 确保有足够的空间显示光标 */
				transition: all 0.1s ease; /* 平滑过渡效果 */
			}

			/* 打字机光标效果 - 增强版 */
			.hero-content .subtitle::after {
				content: "|";
				animation: blink 0.8s infinite;
				color: #fff;
				margin-left: 4px;
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
				/* 根据打字状态调整光标样式 */
				opacity: 1;
			}

			/* 删除状态下的光标样式 */
			.hero-content .subtitle[data-deleting="true"]::after {
				content: "⌫"; /* 退格符号 */
				color: #ff6b6b; /* 红色表示删除状态 */
				animation: blinkDelete 0.6s infinite;
			}

			@keyframes blink {
				0%,
				100% {
					opacity: 1;
				}
				50% {
					opacity: 0;
				}
			}

			@keyframes blinkDelete {
				0%,
				100% {
					opacity: 1;
					transform: scale(1.2);
				}
				50% {
					opacity: 0.3;
					transform: scale(1);
				}
			}

			/* 打字机文本变化时的淡入效果 */
			.hero-content .subtitle.changing {
				opacity: 0.8;
				transform: translateY(-2px);
			}

			/* 新的联系组件样式 - 固定在hero界面右下角 */
			.contact-container {
				position: absolute;
				bottom: 2rem;
				right: 22rem;
				display: flex;
				align-items: center;
				background: rgba(255, 255, 255, 0.2);
				border-radius: 26px;
				padding: 0.5rem 0.8rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				-moz-backdrop-filter: blur(12px);
				-o-backdrop-filter: blur(12px);
				-ms-backdrop-filter: blur(12px);
				z-index: 10;
				gap: 0.4rem;
				border: 1px solid rgba(255, 255, 255, 0.3);
			}

			.contact-icon {
				width: 32px;
				height: 32px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: rgb(80, 80, 80);
				text-decoration: none;
				font-size: 1rem;
				transition: all 0.2s ease;
				border-radius: 8px;
			}

			.contact-icon:hover {
				background: rgba(255, 255, 255, 0.5);
				transform: translateY(-1px);
				color: #333;
			}

			.contact-divider {
				color: rgba(80, 80, 80, 0.6);
				font-size: 1.2rem;
				font-weight: bold;
				line-height: 1;
				user-select: none;
				margin: 0 0.3rem;
			}

			/* 气泡聊天框样式 */
			.contact-icon-with-tooltip {
				position: relative;
				display: inline-block;
			}

			.tooltip-bubble {
				position: absolute;
				bottom: 120%;
				right: 50%;
				transform: translateX(50%);
				background: rgba(255, 255, 255, 0.95);
				border-radius: 12px;
				padding: 0.8rem 1.2rem;
				box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.3);
				opacity: 0;
				visibility: hidden;
				transition: all 0.3s cubic-bezier(0.17, 0.67, 0.88, 1.06);
				z-index: 20;
				min-width: 200px;
				max-width: 280px;
				margin-bottom: 12px;
			}

			.tooltip-bubble .tooltip-content {
				color: rgb(80, 80, 80);
				font-size: 0.9rem;
				line-height: 1.5;
				/* 添加居中对齐 */
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				height: 100%;
			}

			.tooltip-bubble .tooltip-content p {
				margin: 0.3rem 0;
			}

			.tooltip-arrow {
				position: absolute;
				top: 100%;
				right: 50%;
				transform: translateX(50%) rotate(45deg);
				width: 10px;
				height: 10px;
				background: rgba(255, 255, 255, 0.95);
				border-right: 1px solid rgba(255, 255, 255, 0.3);
				border-bottom: 1px solid rgba(255, 255, 255, 0.3);
				z-index: 1;
			}

			/* 悬停效果 */
			.contact-icon-with-tooltip:hover .tooltip-bubble {
				opacity: 1;
				visibility: visible;
				transform: translateX(50%) translateY(-8px);
			}

			/* 动画效果 */
			.tooltip-bubble {
				transform: translateX(50%) translateY(10px);
			}

			.contact-icon-with-tooltip:hover .tooltip-bubble {
				transform: translateX(50%) translateY(-8px);
			}

			/* 移除原有的contact-buttons样式 */
			.contact-buttons {
				display: none;
			}

			.contact-btn {
				display: none;
			}

			.contact-separator {
				display: none;
			}

			.hero-bottom {
				position: absolute;
				left: 50%;
				bottom: 2rem;
				transform: translateX(-50%);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.9rem;
			}
			.hero-social {
				display: flex;
				gap: 0.6rem;
			}
			.hero-side {
				position: absolute;
				right: 1.5rem;
				top: 50%;
				transform: translateY(-50%);
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
			}
			.circle-btn {
				width: 36px;
				height: 36px;
				border-radius: 999px;
				border: none;
				outline: none;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				background: rgba(255, 255, 255, 0.88);
				color: rgb(80, 80, 80);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
				cursor: pointer;
				text-decoration: none;
				font-size: 0.95rem;
				transition:
					transform 0.1s ease,
					box-shadow 0.15s ease,
					background 0.15s ease;
			}
			.circle-btn:hover {
				transform: translateY(-1px);
				box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
				background: #fff;
			}
			.hero-side .side-btn {
				background: rgba(255, 192, 203, 0.92);
				color: #a83c5f;
			}
			.home-intro h2 {
				margin: 0 0 0.75rem;
				font-size: 1.5rem;
			}
			.home-intro p {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.98rem;
				line-height: 1.9;
			}

			/* 最新文章组件 - 精简版 */
			.latest-posts-section {
				padding: 3rem 0;
				background: rgb(var(--white));
				max-width: 1200px;
				margin: 0 auto;
			}

			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 2rem;
				padding-bottom: 0.8rem;
				border-bottom: 1px solid rgba(var(--gray), 15%);
			}

			.section-title {
				font-size: 1.8rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0;
				position: relative;
			}

			.section-title::after {
				content: "";
				position: absolute;
				bottom: -0.4rem;
				left: 0;
				width: 50px;
				height: 2px;
				background: linear-gradient(90deg, var(--accent), #667eea);
				border-radius: 2px;
			}

			.view-all-link {
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				transition: all 0.3s ease;
				font-size: 0.95rem;
			}

			.view-all-link:hover {
				color: var(--accent-dark);
				transform: translateX(3px);
			}

			.view-all-link svg {
				width: 14px;
				height: 14px;
				margin-left: 3px;
				transition: transform 0.3s ease;
			}

			.view-all-link:hover svg {
				transform: translateX(2px);
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 2rem;
				max-width: 1200px;
				margin: 0 auto;
			}

			.post-card {
				background: white;
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 3px 8px rgba(var(--gray), 6%);
				transition: all 0.3s ease;
				text-decoration: none;
				display: block;
				border: 1px solid rgba(var(--gray), 6%);
			}

			.post-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 20px rgba(var(--gray), 12%);
				border-color: rgba(var(--accent), 12%);
			}

			.post-image-wrapper {
				position: relative;
				height: 160px;
				overflow: hidden;
			}

			.post-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s ease;
			}

			.post-card:hover .post-image {
				transform: scale(1.02);
			}

			.post-content {
				padding: 1.2rem 1rem;
			}

			.post-title {
				font-size: 1.2rem;
				font-weight: 600;
				color: rgb(var(--black));
				margin: 0 0 0.8rem 0;
				line-height: 1.4;
				transition: color 0.3s ease;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.post-card:hover .post-title {
				color: var(--accent);
			}

			.post-meta {
				display: flex;
				align-items: center;
				color: rgb(var(--gray));
				font-size: 0.85rem;
				gap: 0.8rem;
			}

			.post-date {
				display: flex;
				align-items: center;
			}

			.post-date svg {
				width: 12px;
				height: 12px;
				margin-right: 0.4rem;
				fill: currentColor;
			}

			/* 分类和标签样式 */
			.post-category {
				display: inline-block;
				padding: 0.3rem 0.8rem;
				background: rgba(var(--accent), 10%);
				color: var(--accent);
				border-radius: 20px;
				font-size: 0.75rem;
				font-weight: 600;
				margin-bottom: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}

			.post-tags {
				display: flex;
				gap: 0.6rem;
				margin-bottom: 1rem;
				flex-wrap: wrap;
			}

			.post-tag {
				padding: 0.2rem 0.6rem;
				background: rgba(var(--gray), 10%);
				color: rgb(var(--gray));
				border-radius: 20px;
				font-size: 0.7rem;
				font-weight: 500;
				transition: all 0.2s ease;
			}

			.post-tag:hover {
				background: rgba(var(--gray), 20%);
				color: rgb(var(--black));
			}

			/* 响应式优化 */
			@media (max-width: 768px) {
				.latest-posts-section {
					padding: 2.5rem 1rem;
				}

				.section-header {
					flex-direction: column;
					gap: 1.2rem;
					text-align: center;
					border-bottom: none;
					padding-bottom: 0;
				}

				.section-title::after {
					left: 50%;
					transform: translateX(-50%);
				}

				.posts-grid {
					grid-template-columns: 1fr;
				}

				.post-image-wrapper {
					height: 140px;
				}

				.post-content {
					padding: 1rem 0.8rem;
				}

				.post-title {
					font-size: 1.1rem;
				}

				.post-category {
					font-size: 0.7rem;
					padding: 0.25rem 0.7rem;
				}

				.post-tags {
					gap: 0.4rem;
				}

				.post-tag {
					font-size: 0.65rem;
					padding: 0.15rem 0.5rem;
				}
			}

			@media (max-width: 480px) {
				.section-title {
					font-size: 1.6rem;
				}

				.post-image-wrapper {
					height: 120px;
				}

				.post-content {
					padding: 0.9rem 0.7rem;
				}

				.post-category {
					font-size: 0.65rem;
					padding: 0.2rem 0.6rem;
				}

				.post-tag {
					font-size: 0.6rem;
					padding: 0.1rem 0.4rem;
				}
			}
