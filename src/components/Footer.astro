---
/**
 * 网站底部信息组件
 *
 * 作用：
 * - 显示网站版权和备案信息
 * - 提供社交媒体链接
 * - 展示站点统计信息
 * - 包含RSS订阅和Sitemap链接
 * - 显示技术栈相关信息
 *
 * 相关文件：
 * - src/consts.ts：网站基本信息和社交链接
 * - src/styles/global.css：底部样式定义
 * - 所有页面布局文件：都会引入此组件
 * - package.json：项目技术栈信息来源
 *
 * 主要内容：
 * - 版权声明和备案号
 * - 社交媒体图标链接
 * - 站点运行统计
 * - 技术栈展示
 * - 友情链接区域
 */
import { SITE_TITLE } from "../consts";
import { getCollection } from "astro:content";
import gongan from "../assets/备案图标.png";

// 获取文章数量和字数统计
const posts = await getCollection("blog");
const totalWords = posts.reduce((sum, post) => {
	const content = post.body || "";
	return sum + content.split(/\s+/).length;
}, 0);

// 博客启动时间（仅用于服务端渲染初始值）
const BLOG_START_TIME = "2025-09-07T14:00:00";
// 简化的初始时间对象（服务端只需渲染占位符）
const initialTime = {
	days: 0,
	hours: 0,
	minutes: 0,
	seconds: 0,
};

// ICP备案信息 - 每个备案项对应不同的跳转地址
const icpInfo = [
	{ text: "鲁ICP备2025142845号-1", url: "https://beian.miit.gov.cn/" },
	{
		text: "鲁公网安备37172402000442号",
		url: "https://beian.mps.gov.cn/#/query/webSearch?code=37172402000442",
		showIcon: true,
	},
	{ text: "萌ICP备20250716号", url: "https://icp.gov.moe/?keyword=20250716" },
];

// 格式化数字为千分位
function formatNumber(num: number): string {
	return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
}
---

<footer>
	<div class="footer-content">
		<!-- 版权信息 -->
		<div class="copyright">
			© 2025 - {new Date().getFullYear()} ❤️ {SITE_TITLE}
		</div>

		<!-- 文章统计 -->
		<div class="stats">
			共撰写了 {posts.length} 篇文章 共 {formatNumber(totalWords)} 字
		</div>

		<!-- ICP备案信息 -->
		<div class="icp-info">
			{
				icpInfo.map((item, index) => (
					<span>
						<a
							href={item.url}
							target="_blank"
							rel="noopener noreferrer"
						>
							{typeof item.text === "string" ? (
								item.showIcon ? (
									<>
										<img
											src={gongan.src}
											alt="公安备案图标"
											style="height: 1.1em; vertical-align: middle; margin-right: 0em;"
										/>
										{item.text}
									</>
								) : (
									item.text
								)
							) : (
								item.text
							)}
						</a>
						{index < icpInfo.length - 1 && " | "}
					</span>
				))
			}
		</div>

		<!-- 运行时间 -->
		<div class="uptime">
			博客已运行
			<span class="uptime-number" data-value="{initialTime.days}"
				>{initialTime.days}</span
			> 天
			<span class="uptime-number" data-value="{initialTime.hours}"
				>{initialTime.hours}</span
			> 小时
			<span class="uptime-number" data-value="{initialTime.minutes}"
				>{initialTime.minutes}</span
			> 分钟
			<span class="uptime-number" data-value="{initialTime.seconds}"
				>{initialTime.seconds}</span
			> 秒
		</div>
	</div>
</footer>

<script is:inline>
	document.addEventListener("DOMContentLoaded", () => {
		// 将启动时间和必要函数传递给客户端
		const BLOG_START_TIME = "2025-09-07T14:00:00";
		const startTime = new Date(BLOG_START_TIME);

		// 直接使用本地时间进行计算
		const MS_PER_SECOND = 1000;
		const MS_PER_MINUTE = 1000 * 60;
		const MS_PER_HOUR = 1000 * 60 * 60;
		const MS_PER_DAY = 1000 * 60 * 60 * 24;

		function calculateTimeDiff(startDate, endDate = new Date()) {
			// 直接使用本地时间计算
			const diff = endDate.getTime() - startDate.getTime();
			const days = Math.floor(diff / MS_PER_DAY);
			const remainingAfterDays = diff % MS_PER_DAY;
			const hours = Math.floor(remainingAfterDays / MS_PER_HOUR);
			const remainingAfterHours = remainingAfterDays % MS_PER_HOUR;
			const minutes = Math.floor(remainingAfterHours / MS_PER_MINUTE);
			const seconds = Math.floor(
				(remainingAfterHours % MS_PER_MINUTE) / MS_PER_SECOND,
			);
			return { days, hours, minutes, seconds };
		}
		const uptimeElements = document.querySelectorAll(".uptime-number");

		// 初始化数字显示
		function updateUptime() {
			const currentTime = calculateTimeDiff(startTime);
			const values = [
				currentTime.days,
				currentTime.hours,
				currentTime.minutes,
				currentTime.seconds,
			];

			uptimeElements.forEach((el, index) => {
				const currentValue = parseInt(el.dataset.value || "0");
				const targetValue = values[index];

				// 更新data-value属性用于下次比较
				el.dataset.value = targetValue.toString();

				// 总是更新文本内容，确保显示最新值
				el.textContent = targetValue.toString();

				// 如果数值变化，添加动画效果
				if (currentValue !== targetValue) {
					// 添加动画类
					el.classList.add("animate-change");

					// 动画结束后清理类名
					setTimeout(() => {
						el.classList.remove("animate-change");
					}, 500);
				}
			});
		}

		// 初始更新
		updateUptime();

		// 每秒更新一次
		setInterval(updateUptime, 1000);
	});
</script>

<style>
	footer {
		padding: 2em 1em 1em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.9rem;
	}

	.footer-content {
		margin-bottom: 1.5em;
		line-height: 1.8;
	}

	.copyright {
		font-weight: 600;
		margin-bottom: 0.5em;
		font-size: 1.1rem;
	}

	.stats,
	.icp-info,
	.uptime {
		margin-bottom: 0.5em;
		font-size: 0.95rem;
	}

	.icp-info {
		color: (var(--gray-dark));
	}

	.uptime {
		color: rgb(var(--accent));
		font-weight: 500;
	}

	.uptime-number {
		display: inline-block;
		font-weight: 600;
		transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		will-change: transform;
	}

	.uptime-number.animate-change {
		transform: scale(1.3) translateY(-2px);
		color: rgb(var(--accent-light));
		text-shadow: 0 0 8px rgba(var(--accent), 0.3);
	}

	.icp-info a {
		color: inherit;
		text-decoration: none;
		transition: color 0.3s ease;
	}

	.icp-info a:hover {
		color: #a31f34;
	}
</style>
