---
import { parseChinaTime, formatChinaTime } from "../utils/blogUtils";

interface Props {
	date: Date | string; // 支持Date对象或ISO时间字符串
	showTimezone?: boolean; // 是否显示时区信息
}

const { date, showTimezone = false } = Astro.props;

// 智能处理时间
let displayDate: Date;
if (typeof date === 'string') {
	displayDate = parseChinaTime(date);
} else {
	displayDate = date;
}

// 格式化显示
const formattedTime = formatChinaTime(
	typeof date === 'string' ? date : date.toISOString(), 
	showTimezone
);
---

<time datetime={displayDate.toISOString()}>
	{formattedTime}
</time>
