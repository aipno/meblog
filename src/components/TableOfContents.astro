---

<div class="toc-widget">
	<style is:global>
		.toc-widget {
			background: transparent;
			border-radius: 0;
			box-shadow: none;
			padding: 0;
			position: sticky;
			top: 1.5rem;
			max-height: 70vh;
			overflow-y: auto;
		}

		.toc-title {
			font-size: 0.95rem;
			font-weight: 600;
			color: rgb(var(--black));
			margin: 0 0 0.75rem 0;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.5rem;
			cursor: pointer;
		}

		.toc-title-label {
			display: inline-flex;
			align-items: center;
			gap: 0.35rem;
		}

		.toc-title-icon {
			font-size: 1rem;
		}

		.toc-title::after {
			content: "▾";
			font-size: 0.75rem;
			color: rgb(var(--gray));
			transition: transform 0.2s ease;
		}

		.toc-widget.collapsed {
			max-height: none;
		}

		.toc-widget.collapsed #toc-container {
			display: none;
		}

		.toc-widget.collapsed .toc-title::after {
			transform: rotate(-90deg);
		}

		.toc-list {
			list-style: none;
			padding: 0;
			margin: 0;
		}

		.toc-item + .toc-item {
			margin-top: 0.25rem;
		}

		.toc-link {
			display: flex;
			align-items: flex-start;
			gap: 0.4rem;
			padding: 0.25rem 0.35rem;
			color: rgb(var(--gray));
			text-decoration: none;
			border-radius: 4px;
			font-size: 0.9rem;
			transition: all 0.2s ease;
			line-height: 1.5;
		}

		.toc-link-bullet {
			flex-shrink: 0;
			width: 0.35rem;
			height: 0.35rem;
			border-radius: 999px;
			background: rgba(var(--gray), 45%);
			margin-top: 0.45rem;
		}

		.toc-link-label {
			flex: 1;
		}

		.toc-link:hover {
			color: var(--accent);
			background: rgba(var(--accent), 10%);
		}

		.toc-link.active {
			color: var(--accent);
			font-weight: 600;
			background: rgba(var(--accent), 16%);
		}

		.toc-link.active .toc-link-bullet {
			background: var(--accent);
		}

		.toc-link.level-2 {
			padding-left: 0.6rem;
		}

		.toc-link.level-3 {
			padding-left: 1.3rem;
			font-size: 0.85rem;
		}

		.toc-widget::-webkit-scrollbar {
			width: 6px;
		}

		.toc-widget::-webkit-scrollbar-track {
			background: transparent;
		}

		.toc-widget::-webkit-scrollbar-thumb {
			background: rgba(var(--gray), 30%);
			border-radius: 3px;
		}

		.toc-widget::-webkit-scrollbar-thumb:hover {
			background: rgba(var(--gray), 50%);
		}

		@media (max-width: 1024px) {
			.toc-widget {
				position: static;
				margin-bottom: 1.5rem;
				max-height: none;
			}

			.toc-link {
				font-size: 0.9rem;
				padding: 0.25rem 0.3rem;
			}

			.toc-link.level-2 {
				padding-left: 0.8rem;
			}

			.toc-link.level-3 {
				padding-left: 1.4rem;
			}
		}

		@media (max-width: 768px) {
			.toc-title {
				font-size: 0.95rem;
			}

			.toc-link {
				font-size: 0.85rem;
			}
		}
	</style>

	<h3 class="toc-title" aria-expanded="true">
		<span class="toc-title-label">
			<span class="toc-title-icon">📋</span>
			<span>目录</span>
		</span>
	</h3>

	<div id="toc-container"></div>
</div>

<script is:inline>
	(function () {
		function collectHeadings() {
			return Array.from(
				document.querySelectorAll(
					".article-body h2, .article-body h3, .article-body h4",
				),
			);
		}

		function buildToc() {
			const container = document.getElementById("toc-container");
			if (!container) return;

			const headings = collectHeadings();
			if (headings.length === 0) {
				container.innerHTML = "";
				return;
			}

			headings.forEach((header, index) => {
				if (!header.id) {
					header.id = `heading-${index}`;
				}
			});

			const list = document.createElement("ul");
			list.className = "toc-list";

			headings.forEach((header, index) => {
				const level = parseInt(header.tagName.charAt(1), 10);
				const text = header.textContent ? header.textContent.trim() : "";
				if (!text) return;

				const id = header.id || `heading-${index}`;

				const item = document.createElement("li");
				item.className = "toc-item";

				const link = document.createElement("a");
				link.href = `#${id}`;
				link.className = `toc-link level-${level}`;

				const bullet = document.createElement("span");
				bullet.className = "toc-link-bullet";

				const label = document.createElement("span");
				label.className = "toc-link-label";
				label.textContent = text;

				link.appendChild(bullet);
				link.appendChild(label);

				link.addEventListener("click", (event) => {
					event.preventDefault();
					const target = document.getElementById(id);
					if (!target) return;
					const rect = target.getBoundingClientRect();
					const scrollTop =
						window.pageYOffset || document.documentElement.scrollTop;
					const offset = 96;
					window.scrollTo({
						top: scrollTop + rect.top - offset,
						behavior: "smooth",
					});
				});

				item.appendChild(link);
				list.appendChild(item);
			});

			container.innerHTML = "";
			container.appendChild(list);

			setupScrollSpy(headings);
		}

		function setupScrollSpy(headings) {
			const links = Array.from(document.querySelectorAll(".toc-link"));
			if (headings.length === 0 || links.length === 0) return;

			let activeId = null;

			const observer = new IntersectionObserver(
				(entries) => {
					const visible = entries
						.filter((entry) => entry.isIntersecting)
						.sort(
							(a, b) =>
								a.target.getBoundingClientRect().top -
								b.target.getBoundingClientRect().top,
						);

					if (visible.length === 0) return;
					const id = visible[0].target.id;
					if (!id || id === activeId) return;
					activeId = id;

					links.forEach((link) => {
						link.classList.remove("active");
					});

					const activeLink = document.querySelector(
						`.toc-link[href="#${id}"]`,
					);
					if (activeLink) {
						activeLink.classList.add("active");
					}
				},
				{
					rootMargin: "-120px 0px -60% 0px",
					threshold: 0.1,
				},
			);

			headings.forEach((heading) => {
				observer.observe(heading);
			});
		}

		function initToggle() {
			const widget = document.querySelector(".toc-widget");
			const title = widget ? widget.querySelector(".toc-title") : null;
			if (!widget || !title) return;

			title.addEventListener("click", () => {
				const isCollapsed = widget.classList.toggle("collapsed");
				title.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
			});
		}

		function init() {
			buildToc();
			initToggle();
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}

		window.addEventListener("load", () => {
			setTimeout(buildToc, 100);
		});
	})();
</script>
