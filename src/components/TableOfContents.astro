---

<div class="toc-widget">
	<style is:global>
		.toc-widget {
			background: white;
			border-radius: var(--border-radius-lg);
			box-shadow: var(--shadow-lg);
			padding: 1rem;
			position: sticky;
			top: 1.5rem;
			max-height: 70vh;
			overflow-y: auto;
			border: 1px solid rgba(var(--gray), 10%);
		}

		.toc-title {
			font-size: 1rem;
			font-weight: 600;
			color: rgb(var(--black));
			margin: 0 0 1rem 0;
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}

		.toc-list {
			list-style: none;
			padding: 0;
			margin: 0;
		}

		.toc-item {
			margin-bottom: 0.5rem;
		}

		.toc-link {
			display: block;
			padding: 0.4rem 0.6rem;
			color: rgb(var(--gray));
			text-decoration: none;
			border-radius: 4px;
			font-size: 0.95rem;
			transition: all 0.3s ease;
			line-height: 1.4;
		}

		.toc-link:hover {
			color: var(--accent);
			background: rgba(var(--accent), 10%);
		}

		.toc-link.active {
			color: var(--accent);
			font-weight: 600;
			background: rgba(var(--accent), 10%);
		}

		.toc-link.level-1 {
			font-weight: 600;
			color: rgb(var(--black));
		}

		.toc-link.level-2 {
			padding-left: 1rem;
			color: rgb(var(--gray));
			font-size: 0.9rem;
		}

		.toc-link.level-3 {
			padding-left: 2rem;
			color: rgb(var(--gray));
			font-size: 0.85rem;
		}

		/* 滚动条样式优化 */
		.toc-widget::-webkit-scrollbar {
			width: 6px;
		}

		.toc-widget::-webkit-scrollbar-track {
			background: transparent;
		}

		.toc-widget::-webkit-scrollbar-thumb {
			background: rgba(var(--gray), 30%);
			border-radius: 3px;
		}

		.toc-widget::-webkit-scrollbar-thumb:hover {
			background: rgba(var(--gray), 50%);
		}

		@media (max-width: 1024px) {
			.toc-widget {
				position: static;
				margin-bottom: 1.5rem;
				max-height: 50vh;
				border-radius: var(--border-radius-md);
			}

			.toc-link {
				font-size: 0.9rem;
				padding: 0.4rem 0.5rem;
			}

			.toc-link.level-2 {
				padding-left: 1.2rem;
			}

			.toc-link.level-3 {
				padding-left: 2.2rem;
			}
		}

		@media (max-width: 768px) {
			.toc-widget {
				padding: 0.75rem;
			}

			.toc-title {
				font-size: 1rem;
			}
		}
	</style>

	<h3 class="toc-title">
		<span>📋</span>
		<span>目录</span>
	</h3>

	<div id="toc-container">
		<!-- 目录内容将通过JavaScript动态生成 -->
	</div>
</div>

<script is:inline>
	// 简化目录生成功能 - 采用扁平化结构，匹配图片样式
	function generateTableOfContents() {
		const headers = document.querySelectorAll(
			".article-body h2, .article-body h3, .article-body h4",
		);
		const tocContainer = document.getElementById("toc-container");

		if (!tocContainer || headers.length === 0) return;

		tocContainer.innerHTML = "<ul class='toc-list'></ul>";
		const listElement = tocContainer.querySelector(".toc-list");

		headers.forEach((header, index) => {
			const level = parseInt(header.tagName.charAt(1));
			const text = header.textContent.trim();
			const id = `heading-${index}`;

			header.id = id;

			const listItem = document.createElement("li");
			listItem.className = `toc-item toc-level-${level}`;
			
			const link = document.createElement("a");
			link.href = `#${id}`;
			link.className = `toc-link toc-level-${level} level-${level}`;
			link.textContent = text;

			link.addEventListener("click", (e) => {
				e.preventDefault();
				const target = document.getElementById(id);
				if (target) {
					target.scrollIntoView({
						behavior: "smooth",
						block: "center",
					});
				}
			});

			listItem.appendChild(link);
			listElement.appendChild(listItem);
		});

		// 初始化高亮
		highlightActiveTocItem();
	}

	// 高亮当前活动的目录项
	function highlightActiveTocItem() {
		const headers = document.querySelectorAll(
			".article-body h2, .article-body h3, .article-body h4",
		);
		const tocLinks = document.querySelectorAll(".toc-link");

		if (headers.length === 0 || tocLinks.length === 0) return;

		function setActive() {
			const scrollTop =
				window.pageYOffset || document.documentElement.scrollTop;

			// 移除所有活动状态
			tocLinks.forEach((link) => link.classList.remove("active"));

			// 找到当前应该激活的标题
			let activeIndex = -1;
			for (let i = headers.length - 1; i >= 0; i--) {
				const header = headers[i];
				const headerTop = header.offsetTop;
				if (scrollTop >= headerTop - 100) {
					activeIndex = i;
					break;
				}
			}

			// 设置对应的TOC链接为活动状态
			if (activeIndex >= 0) {
				const activeLinkId = headers[activeIndex].id;
				const activeLink = document.querySelector(
					`.toc-link[href="#${activeLinkId}"]`,
				);
				if (activeLink) {
					activeLink.classList.add("active");
				}
			}
		}

		window.addEventListener("scroll", setActive);
		setActive();
	}

	// 初始化
	document.addEventListener("DOMContentLoaded", () => {
		generateTableOfContents();
	});

	// 页面加载完成后重新生成（处理异步内容）
	window.addEventListener("load", () => {
		setTimeout(() => {
			generateTableOfContents();
		}, 100);
	});
</script>
