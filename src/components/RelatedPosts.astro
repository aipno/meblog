---
interface Props {
	currentTitle: string;
	tags?: string[];
}

const { currentTitle, tags } = Astro.props;
---

<div class="related-posts">
	<style is:global>
		.related-posts {
			background: white;
			border-radius: var(--border-radius-md);
			box-shadow: var(--shadow-md);
			padding: 1.5rem;
			margin-top: 1rem;
		}

		.related-title {
			font-size: 1.2rem;
			font-weight: 700;
			color: #2c3e50;
			margin: 0 0 1.5rem 0;
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}

		.related-list {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.related-item {
			display: block;
			text-decoration: none;
			color: inherit;
			border-radius: 8px;
			overflow: hidden;
			transition: all 0.3s ease;
			border: 1px solid #eee;
		}

		.related-item:hover {
			transform: translateY(-2px);
			box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
			border-color: #3498db;
		}

		.related-content {
			padding: 1rem;
		}

		.related-title-text {
			font-size: 1rem;
			font-weight: 600;
			color: #2c3e50;
			margin: 0 0 0.5rem 0;
			line-height: 1.4;
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.related-excerpt {
			font-size: 0.85rem;
			color: #7f8c8d;
			line-height: 1.5;
			margin: 0 0 0.75rem 0;
			display: -webkit-box;
			-webkit-line-clamp: 3;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.related-meta {
			display: flex;
			justify-content: space-between;
			align-items: center;
			font-size: 0.8rem;
			color: #95a5a6;
		}

		.related-date {
			display: flex;
			align-items: center;
			gap: 0.25rem;
		}

		.related-tags {
			display: flex;
			gap: 0.25rem;
		}

		.related-tag {
			background: #ecf0f1;
			color: #7f8c8d;
			padding: 0.1rem 0.5rem;
			border-radius: 10px;
			font-size: 0.7rem;
		}

		.loading-placeholder {
			text-align: center;
			padding: 2rem;
			color: #95a5a6;
		}

		.loading-spinner {
			display: inline-block;
			width: 20px;
			height: 20px;
			border: 2px solid #f3f3f3;
			border-top: 2px solid #3498db;
			border-radius: 50%;
			animation: spin 1s linear infinite;
			margin-right: 0.5rem;
		}

		.no-related-posts {
			text-align: center;
			padding: 2rem;
			color: #95a5a6;
			font-style: italic;
		}

		.refresh-button {
			background: #3498db;
			color: white;
			border: none;
			padding: 0.5rem 1rem;
			border-radius: 6px;
			cursor: pointer;
			font-size: 0.9rem;
			transition: all 0.2s ease;
			margin-top: 1rem;
		}

		.refresh-button:hover {
			background: #2980b9;
			transform: translateY(-1px);
		}

		@keyframes spin {
			0% {
				transform: rotate(0deg);
			}
			100% {
				transform: rotate(360deg);
			}
		}

		@media (max-width: 1024px) {
			.related-posts {
				margin-top: 0;
			}
		}
	</style>

	<h3 class="related-title">
		<span>🎯</span>
		<span>相关推荐</span>
	</h3>

	<div class="related-list" id="related-posts-list">
		<div class="loading-placeholder">
			<span class="loading-spinner"></span>
			正在为您推荐相关内容...
		</div>
	</div>

	<button
		class="refresh-button"
		onclick="loadRelatedPosts()"
		id="refresh-button"
		style="display: none;"
	>
		🔄 刷新推荐
	</button>
</div>

<script is:inline>
	// 获取相关文章的函数
	async function loadRelatedPosts() {
		const listContainer = document.getElementById("related-posts-list");
		const refreshButton = document.getElementById("refresh-button");

		if (!listContainer) return;

		// 显示加载状态
		listContainer.innerHTML = `
			<div class="loading-placeholder">
				<span class="loading-spinner"></span>
				正在为您推荐相关内容...
			</div>
		`;
		refreshButton.style.display = "none";

		try {
			// 模拟获取相关文章（实际项目中应该调用API）
			const relatedPosts = await getMockRelatedPosts();

			if (relatedPosts.length > 0) {
				renderRelatedPosts(relatedPosts);
				refreshButton.style.display = "block";
			} else {
				listContainer.innerHTML = `
					<div class="no-related-posts">
						暂时没有找到相关文章<br/>
						稍后会为您推荐精彩内容
					</div>
				`;
				refreshButton.style.display = "block";
			}
		} catch (error) {
			console.error("加载相关文章失败:", error);
			listContainer.innerHTML = `
				<div class="no-related-posts">
					加载失败，请稍后重试
				</div>
			`;
			refreshButton.style.display = "block";
		}
	}

	// 模拟相关文章数据（实际应该从API获取）
	async function getMockRelatedPosts() {
		// 模拟网络延迟
		await new Promise((resolve) => setTimeout(resolve, 800));

		// 模拟相关文章数据
		return [
			{
				id: 1,
				title: "深入了解JavaScript异步编程",
				excerpt:
					"探索JavaScript中的Promise、async/await等异步编程模式，掌握现代前端开发的核心技能...",
				date: "2024-01-15",
				tags: ["JavaScript", "异步编程"],
				url: "/blog/javascript-async",
			},
			{
				id: 2,
				title: "React Hooks完全指南",
				excerpt:
					"从基础到进阶，全面解析React Hooks的使用方法和最佳实践，让你的函数组件更加强大...",
				date: "2024-01-10",
				tags: ["React", "Hooks"],
				url: "/blog/react-hooks-guide",
			},
			{
				id: 3,
				title: "CSS Grid布局实战教程",
				excerpt:
					"通过实际案例学习CSS Grid布局的强大功能，打造响应式和现代化的网页设计...",
				date: "2024-01-05",
				tags: ["CSS", "Grid"],
				url: "/blog/css-grid-tutorial",
			},
		];
	}

	// 渲染相关文章列表
	function renderRelatedPosts(posts) {
		const listContainer = document.getElementById("related-posts-list");

		if (!listContainer) return;

		const html = posts
			.map(
				(post) => `
			<a href="${post.url}" class="related-item">
				<div class="related-content">
					<h4 class="related-title-text">${post.title}</h4>
					<p class="related-excerpt">${post.excerpt}</p>
					<div class="related-meta">
						<div class="related-date">
							📅 ${post.date}
						</div>
						<div class="related-tags">
							${post.tags.map((tag) => `<span class="related-tag">${tag}</span>`).join("")}
						</div>
					</div>
				</div>
			</a>
		`,
			)
			.join("");

		listContainer.innerHTML = html;
	}

	// 页面加载时自动获取相关文章
	document.addEventListener("DOMContentLoaded", () => {
		// 延迟加载，避免影响主内容渲染
		setTimeout(() => {
			loadRelatedPosts();
		}, 1000);
	});
</script>
