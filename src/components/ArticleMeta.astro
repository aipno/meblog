---
import FormattedDate from "../components/FormattedDate.astro";
import "@/styles/article-meta.css";

interface Props {
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	categories?: string[];
}

const { pubDate, updatedDate, tags, categories } = Astro.props;
---

<div class="article-meta">
	<!-- 发布日期 -->
	<div class="meta-item">
		<span class="meta-icon">📅</span>
		<span class="meta-text">发布于 <FormattedDate date={pubDate} /></span>
	</div>

	<!-- 更新日期 -->
	{
		updatedDate && (
			<div class="meta-item">
				<span class="meta-icon">🔄</span>
				<span class="meta-text">
					更新于 <FormattedDate date={updatedDate} />
					<span
						class="meta-chip updated-badge"
						style="margin-left: 0.5rem;"
					>
						新
					</span>
				</span>
			</div>
		)
	}

	<!-- 分类 -->
	{
		categories && categories.length > 0 && (
			<div class="meta-item">
				<span class="meta-icon">📂</span>
				<div class="meta-chips-container">
					{categories.map((category) => (
						<a href={`/categories/${category}`} class="meta-chip">
							<span>#{category}</span>
						</a>
					))}
				</div>
			</div>
		)
	}

	<!-- 标签 -->
	{
		tags && tags.length > 0 && (
			<div class="meta-item">
				<span class="meta-icon">🏷️</span>
				<div class="meta-chips-container">
					{tags.map((tag) => (
						<a href={`/tags/${tag}`} class="meta-chip">
							<span>{tag}</span>
						</a>
					))}
				</div>
			</div>
		)
	}
</div>
