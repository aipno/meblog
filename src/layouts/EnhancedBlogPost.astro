---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import ArticleMeta from "../components/ArticleMeta.astro";
import TableOfContents from "../components/TableOfContents.astro";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description,
	tags,
	categories,
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;

// 为可能为 undefined 的属性提供默认值
const pageTitle = title || "无标题文章";
const pageDescription = description || "暂无描述";
---

<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style is:global>
			/* 增强的文章页面样式 */
			:root {
				--article-max-width: 800px;
				--sidebar-width: 280px;
				--content-padding: 2rem;
				--border-radius-lg: 16px;
				--border-radius-md: 12px;
				--shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.1);
				--shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
				--transition-base: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.article-page-wrapper {
				min-height: 100vh;
				background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
				padding: 0;
				margin: 0;
			}

			.article-container {
				display: flex;
				max-width: 1400px;
				margin: 0 auto;
				min-height: calc(100vh - 120px);
				gap: 2rem;
				padding: 2rem 1rem;
			}

			/* 主内容区域 */
			.main-content {
				flex: 1;
				max-width: var(--article-max-width);
				background: white;
				border-radius: var(--border-radius-lg);
				box-shadow: var(--shadow-lg);
				overflow: hidden;
				transition: var(--transition-base);
			}

			.main-content:hover {
				transform: translateY(-2px);
				box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
			}

			/* 侧边栏 */
			.sidebar {
				width: var(--sidebar-width);
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			/* Hero 图片区 */
			.hero-section {
				position: relative;
				width: 100%;
				height: 400px;
				overflow: hidden;
			}

			.hero-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: var(--transition-base);
			}

			.hero-overlay {
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: linear-gradient(
					to top,
					rgba(0, 0, 0, 0.7),
					transparent 60%
				);
				display: flex;
				align-items: flex-end;
				padding: 2rem;
			}

			.hero-content {
				color: white;
				max-width: var(--article-max-width);
				margin: 0 auto;
				width: 100%;
			}

			.hero-title {
				font-size: 2.5rem;
				font-weight: 700;
				margin: 0 0 1rem 0;
				text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
			}

			/* 文章内容区 */
			.article-content {
				padding: var(--content-padding);
			}

			.article-header {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid #eee;
			}

			.article-title {
				font-size: 2.2rem;
				font-weight: 700;
				color: #2c3e50;
				margin: 0 0 1.5rem 0;
				line-height: 1.3;
			}

			.article-meta-wrapper {
				background: #f8f9fa;
				padding: 1.5rem;
				border-radius: var(--border-radius-md);
				margin-bottom: 2rem;
			}

			/* 文章正文样式 */
			.article-body {
				font-size: 1.1rem;
				line-height: 1.8;
				color: #34495e;
			}

			.article-body h1,
			.article-body h2,
			.article-body h3,
			.article-body h4,
			.article-body h5,
			.article-body h6 {
				margin: 2rem 0 1rem 0;
				color: #2c3e50;
				scroll-margin-top: 100px;
			}

			.article-body h2 {
				font-size: 1.8rem;
				border-bottom: 2px solid #3498db;
				padding-bottom: 0.5rem;
			}

			.article-body h3 {
				font-size: 1.5rem;
				color: #34495e;
			}

			.article-body p {
				margin-bottom: 1.5rem;
				text-align: justify;
			}

			.article-body ul,
			.article-body ol {
				margin: 1.5rem 0;
				padding-left: 2rem;
			}

			.article-body li {
				margin-bottom: 0.5rem;
			}

			.article-body blockquote {
				margin: 2rem 0;
				padding: 1.5rem 2rem;
				border-left: 4px solid #3498db;
				background: #f8f9fa;
				border-radius: 0 var(--border-radius-md) var(--border-radius-md)
					0;
				font-style: italic;
				color: #555;
			}

			.article-body code {
				background: #f1f2f6;
				padding: 0.2em 0.4em;
				border-radius: 4px;
				font-family: "Monaco", "Consolas", monospace;
				font-size: 0.9em;
				color: #e74c3c;
			}

			.article-body pre {
				background: #2c3e50;
				color: #ecf0f1;
				padding: 1.5rem;
				border-radius: var(--border-radius-md);
				overflow-x: auto;
				margin: 2rem 0;
			}

			.article-body pre code {
				background: none;
				color: inherit;
				padding: 0;
			}

			.article-body img {
				max-width: 100%;
				height: auto;
				border-radius: var(--border-radius-md);
				box-shadow: var(--shadow-md);
				margin: 1.5rem 0;
				display: block;
			}

			.article-body table {
				width: 100%;
				border-collapse: collapse;
				margin: 2rem 0;
				background: white;
				border-radius: var(--border-radius-md);
				overflow: hidden;
				box-shadow: var(--shadow-md);
			}

			.article-body th,
			.article-body td {
				padding: 1rem;
				text-align: left;
				border-bottom: 1px solid #eee;
			}

			.article-body th {
				background: #3498db;
				color: white;
				font-weight: 600;
			}

			.article-body tr:nth-child(even) {
				background: #f8f9fa;
			}

			/* 响应式设计 */
			@media (max-width: 1024px) {
				.article-container {
					flex-direction: column;
				}

				.sidebar {
					width: 100%;
					order: -1;
				}

				.hero-title {
					font-size: 2rem;
				}

				.article-title {
					font-size: 1.8rem;
				}
			}

			@media (max-width: 768px) {
				.article-container {
					padding: 1rem;
				}

				.article-content {
					padding: 1.5rem;
				}

				.hero-section {
					height: 250px;
				}

				.hero-title {
					font-size: 1.5rem;
				}

				.article-title {
					font-size: 1.5rem;
				}

				.article-body {
					font-size: 1rem;
				}
			}

			/* 滚动条美化 */
			::-webkit-scrollbar {
				width: 8px;
			}

			::-webkit-scrollbar-track {
				background: #f1f1f1;
				border-radius: 4px;
			}

			::-webkit-scrollbar-thumb {
				background: #bdc3c7;
				border-radius: 4px;
			}

			::-webkit-scrollbar-thumb:hover {
				background: #95a5a6;
			}
		</style>
	</head>

	<body class="article-page-wrapper">
		<Header />

		<div class="article-container">
			<!-- 主内容区域 -->
			<main class="main-content">
				<!-- Hero 图片区 -->
				{
					heroImage && (
						<section class="hero-section">
							<Image
								width={1200}
								height={600}
								src={heroImage}
								alt={title}
								class="hero-image"
								loading="eager"
							/>
							<div class="hero-overlay">
								<div class="hero-content">
									<h1 class="hero-title">{title}</h1>
								</div>
							</div>
						</section>
					)
				}

				<!-- 文章内容区 -->
				<article class="article-content">
					{
						!heroImage && (
							<header class="article-header">
								<h1 class="article-title">{title}</h1>
							</header>
						)
					}

					<!-- 文章元信息 -->
					<div class="article-meta-wrapper">
						<ArticleMeta
							pubDate={pubDate}
							updatedDate={updatedDate}
							tags={tags}
							categories={categories}
						/>
					</div>

					<!-- 文章正文 -->
					<div class="article-body">
						<slot />
					</div>
				</article>
			</main>

			<!-- 侧边栏 -->
			<aside class="sidebar">
				<TableOfContents />
			</aside>
		</div>
		<Footer />
	</body>
</html>
