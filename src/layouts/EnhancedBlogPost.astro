---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import ArticleMeta from "../components/ArticleMeta.astro";
import TableOfContents from "../components/TableOfContents.astro";

type Props = CollectionEntry<"blog">["data"];

const {
	title,
	description,
	tags,
	categories,
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;

// 为可能为 undefined 的属性提供默认值
const pageTitle = title || "无标题文章";
const pageDescription = description || "暂无描述";
---

<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style is:global>
			/* GitHub风格的Markdown渲染样式 */
			.github-markdown {
				-ms-text-size-adjust: 100%;
				-webkit-text-size-adjust: 100%;
				margin: 0;
				color: #24292f;
				background-color: #ffffff;
				font-family: -apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans",Helvetica,Arial,sans-serif,"Apple Color Emoji","Segoe UI Emoji";
				font-size: 16px;
				line-height: 1.5;
				word-wrap: break-word;
			}

			.github-markdown h1, .github-markdown h2, .github-markdown h3, 
			.github-markdown h4, .github-markdown h5, .github-markdown h6 {
				margin-top: 24px;
				margin-bottom: 16px;
				font-weight: 600;
				line-height: 1.25;
			}

			.github-markdown h1 {
				font-size: 2em;
				border-bottom: 1px solid #eaecef;
				padding-bottom: .3em;
			}

			.github-markdown h2 {
				font-size: 1.5em;
				border-bottom: 1px solid #eaecef;
				padding-bottom: .3em;
			}

			.github-markdown h3 {
				font-size: 1.25em;
			}

			.github-markdown h4 {
				font-size: 1em;
			}

			.github-markdown h5 {
				font-size: .875em;
			}

			.github-markdown h6 {
				font-size: .85em;
				color: #6a737d;
			}

			.github-markdown p {
				margin-top: 0;
				margin-bottom: 16px;
			}

			.github-markdown blockquote {
				margin: 0;
				padding: 0 1em;
				color: #6a737d;
				border-left: .25em solid #dfe2e5;
			}

			.github-markdown ul, .github-markdown ol {
				margin-top: 0;
				margin-bottom: 0;
				padding-left: 2em;
			}

			.github-markdown li+li {
				margin-top: .25em;
			}

			.github-markdown code {
				padding: .2em .4em;
				margin: 0;
				font-size: 85%;
				background-color: rgba(27,31,35,.05);
				border-radius: 3px;
				font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
			}

			.github-markdown pre {
				padding: 16px;
				overflow: auto;
				font-size: 85%;
				line-height: 1.45;
				background-color: #f6f8fa;
				border-radius: 3px;
				border: 1px solid #dfe2e5;
			}

			.github-markdown pre code {
				padding: 0;
				margin: 0;
				overflow: visible;
				line-height: inherit;
				word-wrap: normal;
				background-color: transparent;
				border: 0;
			}

			.github-markdown table {
				display: block;
				width: 100%;
				overflow: auto;
				border-collapse: collapse;
			}

			.github-markdown table th {
				font-weight: 600;
			}

			.github-markdown table th,
			.github-markdown table td {
				padding: 6px 13px;
				border: 1px solid #dfe2e5;
			}

			.github-markdown table tr {
				background-color: #fff;
				border-top: 1px solid #c6cbd1;
			}

			.github-markdown table tr:nth-child(2n) {
				background-color: #f6f8fa;
			}

			.github-markdown img {
				max-width: 100%;
				box-sizing: content-box;
				background-color: #fff;
				border-radius: 3px;
				border: 1px solid #dfe2e5;
			}

			.github-markdown hr {
				height: .25em;
				padding: 0;
				margin: 24px 0;
				background-color: #e1e4e8;
				border: 0;
			}

			/* 文章页面样式 - 简洁清晰版本（匹配图片） */
			:root {
				--article-max-width: 800px;
				--sidebar-width: 260px;
				--content-padding: 2rem;
				--border-radius-lg: 12px;
				--border-radius-md: 8px;
				--shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.06);
				--shadow-md: 0 4px 12px rgba(0, 0, 0, 0.04);
				--transition-base: all 0.3s ease;
				--accent-light: #e6eeff;
			}

			.article-page-wrapper {
				min-height: 100vh;
				background: #f8f9fa;
				padding: 0;
				margin: 0;
			}

			.article-container {
				display: flex;
				max-width: 1200px;
				margin: 0 auto;
				gap: 2rem;
				padding: 2rem 1rem;
			}

			/* 主内容区域 */
			.main-content {
				flex: 1;
				max-width: var(--article-max-width);
				background: white;
				border-radius: var(--border-radius-lg);
				box-shadow: var(--shadow-lg);
				overflow: hidden;
				border: 1px solid rgba(var(--gray), 10%);
			}

			/* 文章头部区域 - 匹配图片中的标题区域 */
			.article-header {
				padding: 2rem;
				border-bottom: 1px solid rgba(var(--gray), 10%);
				background: white;
			}

			.article-title {
				font-size: 2.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0 0 1.5rem 0;
				line-height: 1.3;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-bottom: 1.5rem;
			}

			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.meta-item svg {
				width: 16px;
				height: 16px;
				fill: currentColor;
			}

			.article-description {
				color: rgb(var(--gray));
				font-size: 1.1rem;
				line-height: 1.6;
				margin-bottom: 2rem;
			}

			/* 文章正文区域 - 应用GitHub Markdown样式 */
			.article-body {
				padding: 2rem;
				font-size: 16px;
				line-height: 1.5;
				color: #24292f;
				font-family: -apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans",Helvetica,Arial,sans-serif,"Apple Color Emoji","Segoe UI Emoji";
			}

			.article-body h1,
			.article-body h2,
			.article-body h3,
			.article-body h4,
			.article-body h5,
			.article-body h6 {
				margin: 24px 0 16px 0;
				color: #24292f;
				scroll-margin-top: 100px;
			}

			.article-body h2 {
				font-size: 1.5em;
				border-bottom: 1px solid #eaecef;
				padding-bottom: 0.3em;
			}

			.article-body h3 {
				font-size: 1.25em;
			}

			.article-body p {
				margin-bottom: 16px;
			}

			.article-body ul,
			.article-body ol {
				margin: 16px 0;
				padding-left: 2em;
			}

			.article-body li {
				margin-bottom: 4px;
			}

			.article-body blockquote {
				margin: 16px 0;
				padding: 0 1em;
				color: #6a737d;
				border-left: .25em solid #dfe2e5;
			}

			.article-body code {
				padding: .2em .4em;
				margin: 0;
				font-size: 85%;
				background-color: rgba(27,31,35,.05);
				border-radius: 3px;
				font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
			}

			.article-body pre {
				background: #f6f8fa;
				padding: 16px;
				border-radius: 3px;
				overflow-x: auto;
				margin: 16px 0;
				border: 1px solid #dfe2e5;
				font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
				font-size: 85%;
				line-height: 1.45;
			}

			.article-body pre code {
				background: none;
				color: inherit;
				padding: 0;
				font-size: 100%;
			}

			.article-body img {
				max-width: 100%;
				height: auto;
				border-radius: 3px;
				box-shadow: var(--shadow-md);
				margin: 16px 0;
				display: block;
				border: 1px solid #dfe2e5;
			}

			/* 表格样式 - GitHub风格 */
			.article-body table {
				width: 100%;
				border-collapse: collapse;
				margin: 16px 0;
				background: white;
				border-radius: 3px;
				overflow: hidden;
				box-shadow: var(--shadow-md);
				border: 1px solid #dfe2e5;
				display: block;
				overflow-x: auto;
			}

			.article-body th,
			.article-body td {
				padding: 6px 13px;
				text-align: left;
				border: 1px solid #dfe2e5;
			}

			.article-body th {
				background: #f6f8fa;
				font-weight: 600;
			}

			.article-body tr:nth-child(2n) {
				background: #f6f8fa;
			}

			/* 目录样式 - 匹配图片中的目录 */
			.sidebar {
				width: var(--sidebar-width);
				flex-shrink: 0;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.toc-container {
				background: white;
				border-radius: var(--border-radius-lg);
				box-shadow: var(--shadow-lg);
				border: 1px solid rgba(var(--gray), 10%);
				overflow: hidden;
			}

			.toc-header {
				padding: 1.2rem 1.5rem;
				background: rgba(var(--gray-light), 50%);
				border-bottom: 1px solid rgba(var(--gray), 10%);
				font-weight: 600;
				color: rgb(var(--black));
			}

			.toc-list {
				padding: 1rem;
			}

			.toc-list ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.toc-list li {
				margin-bottom: 0.8rem;
			}

			.toc-list a {
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.95rem;
				display: block;
				padding: 0.4rem 0.6rem;
				border-radius: 4px;
				transition: all 0.3s ease;
			}

			.toc-list a:hover {
				color: var(--accent);
				background: rgba(var(--accent), 10%);
			}

			.toc-list .toc-level-1 > a {
				font-weight: 600;
				color: rgb(var(--black));
			}

			.toc-list .toc-level-2 > a {
				padding-left: 1rem;
				color: rgb(var(--gray));
			}

			.toc-list .toc-level-3 > a {
				padding-left: 2rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}

			/* 响应式设计 */
			@media (max-width: 1024px) {
				.article-container {
					flex-direction: column;
				}

				.sidebar {
					width: 100%;
					order: -1;
				}

				.article-title {
					font-size: 2rem;
				}
			}

			@media (max-width: 768px) {
				.article-container {
					padding: 1rem;
				}

				.article-header,
				.article-body {
					padding: 1.5rem;
				}

				.article-title {
					font-size: 1.8rem;
				}

				.article-meta {
					flex-wrap: wrap;
					gap: 1rem;
				}

				.toc-container {
					border-radius: var(--border-radius-md);
				}
				
				.article-body {
					font-size: 14px;
				}
				
				.article-body pre {
					font-size: 12px;
				}
			}
		</style>
	</head>

	<body class="article-page-wrapper">
		<Header />

		<div class="article-container">
			<!-- 主内容区域 -->
			<main class="main-content">
				<!-- 文章头部区域 -->
				<header class="article-header">
					<h1 class="article-title">{title}</h1>
					
					<div class="article-meta">
						<div class="meta-item">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
								<line x1="16" y1="2" x2="16" y2="6"></line>
								<line x1="8" y1="2" x2="8" y2="6"></line>
								<line x1="3" y1="10" x2="21" y2="10"></line>
							</svg>
							<FormattedDate date={pubDate} />
						</div>
						<div class="meta-item">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
							</svg>
							{Math.ceil((title?.length || 0 + (description?.length || 0)) / 200) + 1} 分钟阅读
						</div>
						<div class="meta-item">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path>
								<path d="M12 15c-1.65 0-3-1.35-3-3s1.35-3 3-3 3 1.35 3 3-1.35 3-3 3z"></path>
							</svg>
							{tags?.length || 0} 个标签
						</div>
					</div>
					
					{description && (
						<p class="article-description">
							{description}
						</p>
					)}
				</header>

				<!-- 文章正文 - 应用GitHub Markdown样式 -->
				<div class="article-body github-markdown">
					<slot />
				</div>
			</main>

			<!-- 侧边栏 - 目录 -->
			<aside class="sidebar">
				<div class="toc-container">
					<div class="toc-header">目录</div>
					<div class="toc-list">
						<TableOfContents />
					</div>
				</div>
			</aside>
		</div>
		<Footer />
	</body>
</html>